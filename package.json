{
  "name": "radioo",
  "version": "1.0.0",
  "private": true,
  "description": "Audio broadcaster — capture devices, apply effects, stream to Icecast/HLS",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rust": "cargo test --manifest-path native/proc-audio-capture/Cargo.toml",
    "test:all": "pnpm test && pnpm test:rust",
    "build:sidecar": "cargo build --release --manifest-path native/proc-audio-capture/Cargo.toml && node scripts/copy-sidecar.mjs",
    "dist:win": "pnpm build:sidecar && vite build && electron-builder --win"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@vitest/ui": "^4.1.4",
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.0.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.radioo.app",
    "productName": "Radioo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/proc-audio-capture",
        "to": "proc-audio-capture",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    }
  }
}
